# Backend Options (Refer to backend/.env.example for details)
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_ENVIRONMENT=development
BACKEND_SECRET_KEY=generate_a_secure_random_hex_string_key_here
BACKEND_MONGODB_URI=mongodb://localhost:27017/scholarai
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# Frontend Options (Refer to frontend/.env.example for details)
VITE_API_URL=http://localhost:8000/api/v1
VITE_ENVIRONMENT=development
