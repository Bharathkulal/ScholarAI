# ==============================================================================
# ScholarAI - Frontend Environment Variables Template
# ==============================================================================

# The absolute endpoint representing the active API gateway backend.
# In local development: http://localhost:8000/api/v1
# In production: https://your-backend-render-app-url/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Google OAuth 2.0 Client ID
# Enter your Google Client ID here (obtained from Google Cloud Console -> APIs & Services -> Credentials)
# Example: 1234567890-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
