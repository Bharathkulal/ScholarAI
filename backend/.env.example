# ==============================================================================
# ScholarAI - Backend Environment Variables Template
# ==============================================================================

# Application Configurations
APP_NAME=ScholarAI
APP_VERSION=1.0.0
APP_ENV=development  # development / staging / production
HOST=0.0.0.0
PORT=8000

# API Versioning Prefix
API_PREFIX=/api/v1

# JWT Token Configurations
# Generate a secure key in production using: openssl rand -hex 32
JWT_SECRET=d308064d4b1a45749bb8dfb7d159a4b8dfb7d159a4b8dfb7d159a4b8
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MongoDB Database Connection Configurations
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=scholarai

# CORS Configuration Settings
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Google OAuth Credentials
# Enter your Google OAuth Client ID and Secret from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
