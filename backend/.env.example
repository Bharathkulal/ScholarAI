# ==============================================================================
# ScholarAI - Backend Environment Variables Template
# ==============================================================================

# Server Configurations
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development  # development / staging / production

# JWT Token Configurations
# Generate a secure key in production using: openssl rand -hex 32
SECRET_KEY=generate_a_secure_random_hex_string_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MongoDB Database Connection Configurations
# Local MongoDB Development URI:
MONGODB_URI=mongodb://localhost:27017/scholarai
# Atlas MongoDB Production URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/scholarai?retryWrites=true&w=majority

# CORS Configuration Settings (must be a JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
